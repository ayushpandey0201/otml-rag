# Gemini API Key (Get from Google AI Studio)
GOOGLE_API_KEY="AIzaSy..."

# Qdrant Configuration (Get from Qdrant Cloud Cluster Dashboard)
QDRANT_URL="https://your-cluster-url.qdrant.io"
QDRANT_API_KEY="your-qdrant-api-key"

# Unstructured API Key (Optional if running locally with docker/libraries, but recommended for SaaS)
# Get from https://unstructured.io/
UNSTRUCTURED_API_KEY="your-unstructured-api-key"
UNSTRUCTURED_URL="https://api.unstructured.io/general/v0/general"

# Google Drive Configuration
# You need a 'credentials.json' file in this directory from Google Cloud Console
# No env var needed for the file path if it's in root, but good to know.
